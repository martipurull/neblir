{
  "name": "neblir",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev | pino-pretty",
    "dev:raw": "next dev",
    "build": "npx prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "node scripts/format.mjs",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:file": "vitest --run",
    "test:typecheck": "tsc -p tsconfig.test.json --noEmit",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "prisma:push": "npx prisma db push",
    "prisma:generate": "npx prisma generate",
    "worker:discord": "tsx scripts/discord-outbox-worker.ts",
    "prepare": "husky",
    "push:pr": "git push -u origin HEAD && (gh pr view --json url -q .url || (gh pr create --fill >/dev/null && gh pr view --json url -q .url))"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.937.0",
    "@aws-sdk/s3-request-presigner": "^3.937.0",
    "@prisma/client": "^6.19.0",
    "@tiptap/html": "^3.20.4",
    "@tiptap/pm": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.4.7",
    "googleapis": "^169.0.0",
    "mongodb": "^6.15.0",
    "next": "16.2.1",
    "next-auth": "^5.0.0-beta.25",
    "pino": "^10.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.53.2",
    "swr": "^2.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@serwist/turbopack": "^9.5.7",
    "@testing-library/react": "^16.0.0",
    "@types/csv-parse": "^1.1.12",
    "@types/node": "^22.13.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "cypress": "^13.13.0",
    "esbuild": "^0.25.12",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "pino-pretty": "^13.1.2",
    "postcss": "^8",
    "prettier": "^3.6.2",
    "prisma": "^6.19.0",
    "serwist": "^9.5.7",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "vitest": "^3.0.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/visitor-keys": {
      "eslint-visitor-keys": "4.2.1"
    },
    "effect": "^3.20.0"
  }
}
