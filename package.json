{
  "name": "neblir",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=11.3.0"
  },
  "scripts": {
    "dev": "next dev | pino-pretty",
    "dev:raw": "next dev",
    "build": "npx prisma generate && next build",
    "start": "next start",
    "lint": "eslint . && npm run knip",
    "lint:fix": "eslint . --fix && npm run knip:fix",
    "knip": "knip --exports",
    "knip:fix": "knip --exports --fix",
    "knip:all": "knip",
    "typecheck": "tsc --noEmit",
    "format": "tsx scripts/format.ts",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:file": "vitest --run",
    "test:typecheck": "tsc -p tsconfig.test.json --noEmit",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "prisma:push": "npx prisma db push",
    "prisma:generate": "npx prisma generate",
    "prisma:backfill:special-abilities": "tsx prisma/scripts/backfillCharacterSpecialAbilities.ts",
    "prisma:backfill:enemy-instance-visibility": "tsx prisma/scripts/backfillEnemyInstanceVisibility.ts",
    "data:import:paths-features": "tsx prisma/scripts/upsertPathsAndFeaturesFromFile.ts",
    "data:import:enemies": "tsx prisma/scripts/upsertEnemiesFromFile.ts",
    "data:import:maps": "tsx prisma/scripts/upsertMapsFromFile.ts",
    "data:import:reference": "tsx prisma/scripts/importReferenceEntries.ts",
    "data:import:reference-json": "tsx prisma/scripts/upsertReferenceEntriesFromFile.ts",
    "data:import:items": "tsx prisma/scripts/upsertItemsFromFile.ts",
    "data:seed:official": "tsx prisma/scripts/seedOfficialDataFromFiles.ts",
    "data:seed:official:dry-run": "tsx prisma/scripts/seedOfficialDataFromFiles.ts --dry-run",
    "worker:discord": "tsx scripts/discord-outbox-worker.ts",
    "smoke:http": "bash scripts/smoke-http.sh",
    "prepare": "node -e \"if (process.env.CI || process.env.VERCEL) process.exit(0); require('child_process').execSync('npx husky', { stdio: 'inherit' })\"",
    "push:pr": "git push -u origin HEAD && (gh pr view --json url -q .url || (gh pr create --fill >/dev/null && gh pr view --json url -q .url))"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.937.0",
    "@aws-sdk/s3-request-presigner": "^3.937.0",
    "@prisma/client": "^6.19.0",
    "@swc/helpers": "0.5.15",
    "@tiptap/html": "^3.20.4",
    "@tiptap/pm": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.4.7",
    "googleapis": "^169.0.0",
    "mongodb": "^6.15.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.25",
    "pino": "^10.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.53.2",
    "swr": "^2.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@serwist/turbopack": "^9.5.7",
    "@testing-library/react": "^16.0.0",
    "@types/csv-parse": "^1.1.12",
    "@types/node": "^22.13.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "cypress": "^15.14.1",
    "esbuild": "^0.25.12",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.1",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "knip": "^6.14.2",
    "lint-staged": "^16.2.7",
    "pino-pretty": "^13.1.2",
    "postcss": "^8",
    "prettier": "^3.6.2",
    "prisma": "^6.19.0",
    "serwist": "^9.5.7",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/visitor-keys": {
      "eslint-visitor-keys": "4.2.1"
    },
    "effect": "^3.20.0",
    "@swc/helpers": "0.5.15",
    "eslint-plugin-react-hooks": "7.0.1"
  },
  "optionalDependencies": {
    "@esbuild/darwin-arm64": "0.25.12",
    "@esbuild/darwin-x64": "0.25.12",
    "@esbuild/linux-x64": "0.25.12",
    "@oxc-parser/binding-darwin-arm64": "0.130.0",
    "@oxc-parser/binding-darwin-x64": "0.130.0",
    "@oxc-parser/binding-linux-x64-gnu": "0.130.0",
    "@oxc-resolver/binding-darwin-arm64": "11.20.0",
    "@oxc-resolver/binding-darwin-x64": "11.20.0",
    "@oxc-resolver/binding-linux-x64-gnu": "11.20.0"
  }
}
