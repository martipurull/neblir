generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["views"]
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

enum ItemAccessType {
  PLAYER
  GAME_MASTER
}

enum ItemType {
  GENERAL_ITEM
  WEAPON
}

enum ItemWeaponAttackRollType {
  RANGE
  MELEE
  GRID
  THROW
}

enum ItemWeaponDamageType {
  BULLET
  BLADE
  SIIKE
  ACID
  FIRE
  ICE
  BLUDGEONING
  ELECTRICITY
  NERVE
  POISON
  OTHER
}

enum ItemAreaType {
  RADIUS
  CONE
}

enum ItemStatus {
  FUNCTIONAL
  BROKEN
  BEYOND_REPAIR
}

enum EquipSlot {
  HAND
  FOOT
  BODY
  HEAD
  BRAIN
}

/** Innate attribute path (matches level-up / character sheet keys). */
enum ItemAttributePath {
  INTELLIGENCE_INVESTIGATION @map("intelligence.investigation")
  INTELLIGENCE_MEMORY @map("intelligence.memory")
  INTELLIGENCE_DEDUCTION     @map("intelligence.deduction")
  WISDOM_SENSE               @map("wisdom.sense")
  WISDOM_PERCEPTION          @map("wisdom.perception")
  WISDOM_INSIGHT             @map("wisdom.insight")
  PERSONALITY_PERSUASION     @map("personality.persuasion")
  PERSONALITY_DECEPTION      @map("personality.deception")
  PERSONALITY_MENTALITY      @map("personality.mentality")
  STRENGTH_ATHLETICS         @map("strength.athletics")
  STRENGTH_RESILIENCE        @map("strength.resilience")
  STRENGTH_BRUTE_FORCE       @map("strength.bruteForce")
  DEXTERITY_MANUAL           @map("dexterity.manual")
  DEXTERITY_STEALTH          @map("dexterity.stealth")
  DEXTERITY_AGILITY          @map("dexterity.agility")
  CONSTITUTION_RESISTANCE_INTERNAL @map("constitution.resistanceInternal")
  CONSTITUTION_RESISTANCE_EXTERNAL @map("constitution.resistanceExternal")
  CONSTITUTION_STAMINA       @map("constitution.stamina")
}

/** General skill key (matches CharacterLearnedSkillsGeneralSkills). */
enum ItemGeneralSkill {
  MECHANICS                  @map("mechanics")
  SOFTWARE                   @map("software")
  GENERAL_KNOWLEDGE          @map("generalKnowledge")
  HISTORY                    @map("history")
  DRIVING                    @map("driving")
  ACROBATICS                 @map("acrobatics")
  AIM                        @map("aim")
  MELEE                      @map("melee")
  GRID                       @map("GRID")
  RESEARCH                   @map("research")
  MEDICINE                   @map("medicine")
  SCIENCE                    @map("science")
  SURVIVAL                   @map("survival")
  STREETWISE                 @map("streetwise")
  PERFORMANCE                @map("performance")
  MANIPULATION_NEGOTIATION   @map("manipulationNegotiation")
}

enum PathName {
  SCIENTIST_DOCTOR
  SURVIVALIST
  ANTIHERO
  SOLDIER
  CON_ARTIST
  SLEUTH
  NERD_HERO
  TECHNO_CRAFTER
  URBAN_ROVER
}

enum Race {
  KINIAN
  HUMAN
  FENNE
  MANFENN
}

enum Religion {
  TRITHEOLOGY
  PANTRITHEOLOGY
  CHRISLAM
  HUMANISM
  CHOSEN_FAITH
  FORE_CAST
  ATHEIST
  AGNOSTIC
}

enum Status {
  ALIVE
  DECEASED
  DERANGED
}

enum CurrencyName {
  CONF
  NORD
  NAS
  HUMF
  MRARK
}

enum ItemSourceType {
  GLOBAL_ITEM
  CUSTOM_ITEM
  UNIQUE_ITEM
  /** Unique item with no global/custom template (name & weight stored on the unique row). */
  STANDALONE
}

enum DiscordIntegrationStatus {
  ACTIVE
  DISABLED
  DEGRADED
}

enum DiscordOutboxStatus {
  PENDING
  PROCESSING
  SENT
  RETRY
  DEAD_LETTER
}

enum RollType {
  GENERAL_ROLL
  ATTACK
  ATTACK_DAMAGE
  DEFENCE
  GRID_DEFENCE
  ITEM_DAMAGE
  INITIATIVE
}

type CharacterCombatInformation {
  armourCurrentHP   Int
  armourMaxHP       Int
  armourMod         Int
  initiativeMod     Int
  meleeAttackMod    Int
  meleeDefenceMod   Int
  rangeAttackMod    Int
  rangeDefenceMod   Int
  throwAttackMod   Int
  speed             Int
  reactionsPerRound Int
  maxCarryWeight    Int
}

type CharacterGeneralInformation {
  age        Int
  avatarKey  String?
  birthplace String
  /** TipTap rich text stored as HTML string */
  backstory  String?
  /** TipTap rich text stored as HTML string */
  summary    String?
  level      Int
  name       String
  surname    String
  profession String
  race       Race
  religion   Religion
  height     Int
  weight     Int
}

type CharacterHealth {
  currentMentalHealth     Int
  currentPhysicalHealth   Int
  deathSaves              CharacterHealthDeathSaves
  innateMentalHealth      Int
  innatePhysicalHealth    Int
  maxMentalHealth         Int
  maxPhysicalHealth       Int
  rolledMentalHealth      Int
  rolledPhysicalHealth    Int
  seriousPhysicalInjuries Int
  seriousTrauma           Int
  status                  Status
}

type CharacterHealthDeathSaves {
  failures  Int
  successes Int
}

type CharacterInnateAttributes {
  constitution CharacterInnateAttributesConstitution
  dexterity    CharacterInnateAttributesDexterity
  intelligence CharacterInnateAttributesIntelligence
  personality  CharacterInnateAttributesPersonality
  strength     CharacterInnateAttributesStrength
  wisdom       CharacterInnateAttributesWisdom
}

type CharacterInnateAttributesConstitution {
  resistanceExternal Int
  resistanceInternal Int
  stamina            Int
}

type CharacterInnateAttributesDexterity {
  agility Int
  manual  Int
  stealth Int
}

type CharacterInnateAttributesIntelligence {
  deduction     Int
  investigation Int
  memory        Int
}

type CharacterInnateAttributesPersonality {
  deception  Int
  mentality  Int
  persuasion Int
}

type CharacterInnateAttributesStrength {
  athletics  Int
  bruteForce Int
  resilience Int
}

type CharacterInnateAttributesWisdom {
  insight    Int
  perception Int
  sense      Int
}

type CharacterLearnedSkills {
  generalSkills CharacterLearnedSkillsGeneralSkills
  specialSkills String[]
}

type CharacterLearnedSkillsGeneralSkills {
  GRID                    Int
  acrobatics              Int
  aim                     Int
  driving                 Int
  generalKnowledge        Int
  history                 Int
  manipulationNegotiation Int
  mechanics               Int
  medicine                Int
  melee                   Int
  performance             Int
  research                Int
  science                 Int
  software                Int
  streetwise              Int
  survival                Int
}

type AreaEffect {
  defenceReactionCost     Int
  defenceRoll             String
  successfulDefenceResult String
}

type ItemDamage {
  damageType      ItemWeaponDamageType[]
  diceType        Int
  numberOfDice    Int
  areaType        ItemAreaType?
  coneLength      Int?
  primaryRadius   Int?
  secondaryRadius Int?
  areaEffect      AreaEffect?
}

model Character {
  id                 String                      @id @default(auto()) @map("_id") @db.ObjectId
  combatInformation  CharacterCombatInformation
  generalInformation CharacterGeneralInformation
  health             CharacterHealth
  innateAttributes   CharacterInnateAttributes
  learnedSkills      CharacterLearnedSkills
  wallet             CharacterCurrency[]
  inventory          ItemCharacter[]
  notes              String[]
  paths              PathCharacter[]
  features           FeatureCharacter[]
  games              GameCharacter[]
  users              CharacterUser[]
  rollEvents         RollEvent[]
}

model CharacterCurrency {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  characterId  String       @db.ObjectId
  currencyName CurrencyName
  quantity     Int          @default(0)

  character Character @relation(fields: [characterId], references: [id])

  @@unique([characterId, currencyName])
  @@index([characterId])
}

model CharacterUser {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  characterId String @db.ObjectId
  userId      String @db.ObjectId

  character Character @relation(fields: [characterId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([characterId, userId])
  @@index([characterId])
  @@index([userId])
}

model ItemCharacter {
  id          String @id @default(auto()) @map("_id") @db.ObjectId

  characterId String   @db.ObjectId
  character   Character @relation(fields: [characterId], references: [id])

  sourceType ItemSourceType
  itemId     String   @db.ObjectId

  quantity       Int         @default(1)
  currentUses    Int         @default(0)
  isEquipped     Boolean     @default(false)
  equipSlots     String[]    @default([])
  customName     String?
  status         ItemStatus  @default(FUNCTIONAL)
  itemLocation   String      @default("carried")

  @@index([characterId])
  @@index([sourceType, itemId])
  @@unique([characterId, sourceType, itemId])
}

/** Snapshot per roll; sort for display: total desc, modifier desc, submittedAt asc. */
type CharacterInitiative {
  characterId        String   @db.ObjectId
  rolledValue        Int
  initiativeModifier Int
  submittedAt        DateTime
}

model Game {
  id               String                  @id @default(auto()) @map("_id") @db.ObjectId
  gameMaster       String                  @db.ObjectId
  imageKey         String?
  name             String
  premise          String?
  nextSession      DateTime?
  lore             String?
  users            GameUser[]
  characters       GameCharacter[]
  customItems      CustomItem[]
  uniqueItems      UniqueItem[]
  invites          GameInvite[]
  initiativeOrder  CharacterInitiative[]
  discordIntegration DiscordIntegration?
  rollEvents       RollEvent[]

  @@index([gameMaster])
}

model DiscordIntegration {
  id                String                   @id @default(auto()) @map("_id") @db.ObjectId
  gameId             String                   @unique @db.ObjectId
  guildId            String
  channelId          String
  installedByUserId  String                   @db.ObjectId
  status             DiscordIntegrationStatus @default(ACTIVE)
  lastError          String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  game             Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  installedByUser  User @relation("DiscordIntegrationInstalledBy", fields: [installedByUserId], references: [id])
  outbox           DiscordOutbox[]

  @@index([installedByUserId])
  @@index([guildId, channelId])
}

model RollEvent {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  gameId        String   @db.ObjectId
  characterId   String?  @db.ObjectId
  rollerUserId  String   @db.ObjectId
  rollType      RollType
  diceExpression String?
  results       Int[]
  total         Int?
  metadata      Json?
  createdAt     DateTime @default(now())

  game       Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  character  Character? @relation(fields: [characterId], references: [id])
  rollerUser User       @relation("RollEventUser", fields: [rollerUserId], references: [id])
  outbox     DiscordOutbox?

  @@index([gameId, createdAt])
  @@index([rollerUserId, createdAt])
}

model DiscordOutbox {
  id            String             @id @default(auto()) @map("_id") @db.ObjectId
  rollEventId    String             @unique @db.ObjectId
  integrationId  String             @db.ObjectId
  status         DiscordOutboxStatus @default(PENDING)
  attemptCount   Int                @default(0)
  lastError      String?
  nextAttemptAt  DateTime           @default(now())
  sentAt         DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  rollEvent    RollEvent           @relation(fields: [rollEventId], references: [id], onDelete: Cascade)
  integration  DiscordIntegration  @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt])
  @@index([integrationId])
}

model GameInvite {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  gameId          String   @db.ObjectId
  invitedUserId   String   @db.ObjectId
  invitedByUserId String   @db.ObjectId
  createdAt       DateTime @default(now())

  game       Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  invitedUser User @relation("GameInviteInvited", fields: [invitedUserId], references: [id], onDelete: Cascade)
  invitedBy   User @relation("GameInviteInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@unique([gameId, invitedUserId])
  @@index([gameId])
  @@index([invitedUserId])
}

model GameUser {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  gameId String @db.ObjectId
  userId String @db.ObjectId

  game Game @relation(fields: [gameId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([gameId, userId])
  @@index([gameId])
  @@index([userId])
}

model GameCharacter {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  gameId      String @db.ObjectId
  characterId String @db.ObjectId

  game      Game      @relation(fields: [gameId], references: [id])
  character Character @relation(fields: [characterId], references: [id])

  @@unique([gameId, characterId])
  @@index([gameId])
  @@index([characterId])
}

model Item {
  id                   String                     @id @default(auto()) @map("_id") @db.ObjectId
  accessType           ItemAccessType
  attackRoll           ItemWeaponAttackRollType[]
  attackMeleeBonus     Int?
  attackRangeBonus     Int?
  attackThrowBonus     Int?
  defenceMeleeBonus    Int?
  defenceRangeBonus    Int?
  gridAttackBonus      Int?
  gridDefenceBonus     Int?
  effectiveRange       Int?
  maxRange             Int?
  confCost             Int
  costInfo             String?
  damage               ItemDamage?
  description          String
  imageKey             String?
  name                 String
  notes                String?
  type                 ItemType
  usage                String?
  weight               Float
  equippable           Boolean                    @default(false)
  equipSlotTypes       String[]                   @default([])
  equipSlotCost        Int?
  maxUses              Int?
  modifiesAttribute    ItemAttributePath?
  attributeMod         Int?
  modifiesSkill        ItemGeneralSkill?
  skillMod             Int?
}

model CustomItem {
  id                   String                     @id @default(auto()) @map("_id") @db.ObjectId
  gameId               String                     @db.ObjectId
  game                 Game                       @relation(fields: [gameId], references: [id])
  attackRoll           ItemWeaponAttackRollType[]
  attackMeleeBonus     Int?
  attackRangeBonus     Int?
  attackThrowBonus     Int?
  defenceMeleeBonus    Int?
  defenceRangeBonus    Int?
  gridAttackBonus      Int?
  gridDefenceBonus     Int?
  effectiveRange       Int?
  maxRange             Int?
  confCost             Int?
  costInfo             String?
  damage               ItemDamage?
  description          String?
  imageKey             String?
  name                 String
  notes                String?
  type                 ItemType
  usage                String?
  weight               Float
  equippable           Boolean? @default(false)
  equipSlotTypes       String[]                   @default([])
  equipSlotCost        Int?
  maxUses              Int?
  modifiesAttribute    ItemAttributePath?
  attributeMod         Int?
  modifiesSkill        ItemGeneralSkill?
  skillMod             Int?
}

model UniqueItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  ownerUserId String   @db.ObjectId
  gameId      String?  @db.ObjectId
  game        Game?    @relation(fields: [gameId], references: [id], onDelete: Cascade)

  // template it’s based on (itemId null when sourceType is STANDALONE)
  sourceType  ItemSourceType
  itemId      String?        @db.ObjectId

  attackRollOverride        ItemWeaponAttackRollType[]
  attackMeleeBonusOverride Int?
  attackRangeBonusOverride Int?
  attackThrowBonusOverride Int?
  defenceMeleeBonusOverride Int?
  defenceRangeBonusOverride Int?
  gridAttackBonusOverride  Int?
  gridDefenceBonusOverride Int?
  effectiveRangeOverride   Int?
  maxRangeOverride         Int?
  confCostOverride         Int?
  costInfoOverride         String?
  damageOverride           ItemDamage?
  descriptionOverride      String?
  imageKeyOverride        String?
  nameOverride             String?
  usageOverride            String?
  weightOverride           Float?
  notesOverride            String?
  specialTag               String?  // e.g. "AMPLIFIED", "PROTOTYPE"
  equippableOverride       Boolean?
  equipSlotTypesOverride   Json?  // String[] when set; null = use template
  equipSlotCostOverride    Int?
  maxUsesOverride          Int?
  modifiesAttributeOverride ItemAttributePath?
  attributeModOverride      Int?
  modifiesSkillOverride     ItemGeneralSkill?
  skillModOverride          Int?
  @@index([ownerUserId])
  @@index([gameId])
}

model Feature {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  description     String
  minPathRank     Int
  maxGrade        Int
  examples        String[]
  applicablePaths PathName[]

  pathFeature      PathFeature[]
  FeatureCharacter FeatureCharacter[]

  @@index([applicablePaths])
  @@index([minPathRank])
}

model FeatureCharacter {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  featureId   String @db.ObjectId
  characterId String @db.ObjectId
  grade       Int

  feature   Feature   @relation(fields: [featureId], references: [id])
  character Character @relation(fields: [characterId], references: [id])

  @@unique([featureId, characterId])
  @@index([featureId])
  @@index([characterId])
}

model Path {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        PathName
  description String?
  baseFeature String

  PathCharacter PathCharacter[]

  applicableFeatures PathFeature[]
}

model PathCharacter {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  pathId      String @db.ObjectId
  characterId String @db.ObjectId
  rank        Int

  path      Path      @relation(fields: [pathId], references: [id])
  character Character @relation(fields: [characterId], references: [id])

  @@unique([pathId, characterId])
  @@index([pathId])
  @@index([characterId])
}

model PathFeature {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  pathId    String @db.ObjectId
  featureId String @db.ObjectId

  path    Path    @relation(fields: [pathId], references: [id])
  feature Feature @relation(fields: [featureId], references: [id])

  @@index([pathId])
  @@index([featureId])
}

model User {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  email String @unique
  name  String

  games               GameUser[]
  characters          CharacterUser[]
  gameInvitesReceived GameInvite[] @relation("GameInviteInvited")
  gameInvitesSent     GameInvite[] @relation("GameInviteInvitedBy")
  discordIntegrationsInstalled DiscordIntegration[] @relation("DiscordIntegrationInstalledBy")
  rollEvents          RollEvent[] @relation("RollEventUser")
}
